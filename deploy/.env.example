############################################
# CONFIGURAÇÃO DO SELF-HOSTING
# Copie para `.env` e ajuste os valores.
# NUNCA faça commit do arquivo .env real.
############################################

# === Domínio público (usado pelo Nginx + Certbot) ===
DOMAIN=app.seudominio.com.br
LETSENCRYPT_EMAIL=admin@seudominio.com.br

# === URLs internas do Supabase (gerado pelo docker-compose) ===
# Em produção, SUPABASE_PUBLIC_URL deve ser https://SEU_DOMINIO
SUPABASE_PUBLIC_URL=https://app.seudominio.com.br
SITE_URL=https://app.seudominio.com.br
ADDITIONAL_REDIRECT_URLS=https://app.seudominio.com.br

# === Banco PostgreSQL ===
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_FORTE_DO_BANCO
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# === Segredos do Supabase ===
# Gere com:  openssl rand -base64 48
JWT_SECRET=TROQUE_POR_UMA_STRING_ALEATORIA_DE_NO_MINIMO_40_CARACTERES

# Gere com:  node deploy/scripts/gen-jwt.js  (usando o JWT_SECRET acima)
ANON_KEY=COLE_AQUI_O_TOKEN_ANON_GERADO
SERVICE_ROLE_KEY=COLE_AQUI_O_TOKEN_SERVICE_ROLE_GERADO

# Senha do Studio (painel admin do Supabase)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=TROQUE_ESTA_SENHA

# Secret para o Kong (gateway)
SECRET_KEY_BASE=$(openssl rand -hex 64)
VAULT_ENC_KEY=$(openssl rand -hex 32)

# === SMTP (necessário para confirmação de e-mail e reset de senha) ===
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=usuario
SMTP_PASS=senha
SMTP_SENDER_NAME=DeployConsole
SMTP_ADMIN_EMAIL=admin@seudominio.com.br

# Desativar criação de novos usuários após primeiro admin? (true/false)
DISABLE_SIGNUP=false

# === Frontend ===
# A imagem do frontend é construída com estas variáveis embutidas
VITE_SUPABASE_URL=https://app.seudominio.com.br
VITE_SUPABASE_PUBLISHABLE_KEY=${ANON_KEY}
VITE_SUPABASE_PROJECT_ID=self-hosted
